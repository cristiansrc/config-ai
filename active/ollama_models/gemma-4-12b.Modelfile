FROM /home/cristiansrc/.lmstudio/models/lmstudio-community/gemma-4-12B-it-QAT-GGUF/gemma-4-12B-it-QAT-Q4_0.gguf

# Configuración óptima para RTX 4080 (16GB VRAM) y modelo de 12B
# (Comentarios movidos para evitar errores de parseo en Ollama)
PARAMETER num_gpu 48
PARAMETER num_ctx 102400
PARAMETER num_thread 8
PARAMETER temperature 0.8

# Template básico para Gemma
TEMPLATE """<start_of_turn>user
{{ if .System }}{{ .System }}
{{ end }}{{ .Prompt }}<end_of_turn>
<start_of_turn>model
{{ .Response }}<end_of_turn>"""
